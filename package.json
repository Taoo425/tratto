{
  "name": "tratto",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/shared",
    "packages/mcp-server",
    "packages/extension"
  ],
  "scripts": {
    "build": "npm run build:shared && npm run build:server && npm run build:ext",
    "build:shared": "npm run build -w @tratto/shared",
    "build:server": "npm run build -w tratto-mcp-server",
    "build:ext": "npm run build -w @tratto/extension",
    "start:server": "node packages/mcp-server/dist/index.js",
    "test:loop": "node packages/mcp-server/dist/test-client.js"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
