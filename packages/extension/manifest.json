{
  "manifest_version": 3,
  "name": "Tratto (dev)",
  "version": "0.2.0",
  "description": "Lets your local coding agent read and draw technical-analysis markup on a finance chart already open in the browser, using the page's own drawing engine. Dev build.",
  "minimum_chrome_version": "116",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://finance.yahoo.com/quote/*/chart*",
        "https://finance.yahoo.com/chart/*"
      ],
      "js": ["content-isolated.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://finance.yahoo.com/quote/*/chart*",
        "https://finance.yahoo.com/chart/*"
      ],
      "js": ["content-main.js"],
      "world": "MAIN",
      "run_at": "document_idle"
    }
  ],
  "permissions": ["tabs", "scripting", "alarms", "storage"],
  "host_permissions": ["https://finance.yahoo.com/*"]
}
